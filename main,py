import os
import random
import logging
from telegram import Update
from telegram.ext import Application, CommandHandler, ContextTypes, MessageHandler, filters

# --- НАСТРОЙКИ ---
BOT_TOKEN = os.environ.get("BOT_TOKEN")
if not BOT_TOKEN:
    raise ValueError("BOT_TOKEN не найден в переменных окружения!")

# Включим логи
logging.basicConfig(
    format="%(asctime)s - %(name)s - %(levelname)s - %(message)s", 
    level=logging.INFO
)

group_photos = {}

async def handle_new_photo(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Автоматически сохраняет все новые фото"""
    if update.effective_chat.type not in ["group", "supergroup"]:
        return

    chat_id = update.effective_chat.id
    
    if update.message and update.message.photo:
        photo_file_id = update.message.photo[-1].file_id
        
        if chat_id not in group_photos:
            group_photos[chat_id] = []
        
        if photo_file_id not in group_photos[chat_id]:
            group_photos[chat_id].append(photo_file_id)
            logging.info(f"Сохранено фото для группы {chat_id}, всего: {len(group_photos[chat_id])}")

async def sex_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_chat.type not in ["group", "supergroup"]:
        await update.message.reply_text("❌ Эта команда работает только в группах!")
        return

    chat = update.effective_chat
    users = []

    try:
        admins = await chat.get_administrators()
        for admin in admins:
            if not admin.user.is_bot:
                users.append(admin.user)
        
        if len(users) < 2:
            async for member in chat.get_members():
                if not member.user.is_bot:
                    users.append(member.user)
                    if len(users) >= 20:
                        break
    except Exception as e:
        logging.error(f"Ошибка получения участников: {e}")
        await update.message.reply_text(
            "❌ Ошибка: бот не может получить список участников.\n"
            "Убедитесь, что бот является администратором группы!"
        )
        return

    if len(users) < 2:
        await update.message.reply_text(
            "❌ Не найдено достаточно участников (нужно минимум 2 человека).\n"
            "Убедитесь, что бот имеет права администратора."
        )
        return

    user1, user2 = random.sample(users, 2)
    
    def get_user_mention(user):
        if user.username:
            return f"@{user.username}"
        return user.full_name or str(user.id)

    name1 = get_user_mention(user1)
    name2 = get_user_mention(user2)
    emojis = ["🍆💦", "🔥", "😈", "🥵", "🍑", "💀", "🤯", "💢"]
    
    await update.message.reply_text(f"{name1} выебал {name2} {random.choice(emojis)}")

async def video_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_chat.type not in ["group", "supergroup"]:
        await update.message.reply_text("❌ Эта команда работает только в группах!")
        return

    chat_id = update.effective_chat.id
    status_msg = await update.message.reply_text("🔍 Ищу случайное фото...")

    if chat_id in group_photos and group_photos[chat_id]:
        random_photo_id = random.choice(group_photos[chat_id])
        await status_msg.delete()
        await update.message.reply_photo(
            photo=random_photo_id,
            caption=f"🎲 Случайное фото (всего: {len(group_photos[chat_id])})"
        )
        return

    await status_msg.edit_text(
        "📭 Нет сохраненных фото!\n\n"
        "Отправьте несколько фото в этот чат, и бот автоматически их запомнит.\n"
        "Затем снова используйте /video"
    )

async def stats_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_chat.type not in ["group", "supergroup"]:
        await update.message.reply_text("❌ Эта команда работает только в группах!")
        return

    chat_id = update.effective_chat.id
    photos_count = len(group_photos.get(chat_id, []))

    await update.message.reply_text(
        f"📊 Статистика группы:\n"
        f"• Сохранено фото: {photos_count}\n\n"
        f"Команды: /sex | /video | /stats | /help"
    )

async def help_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🤖 Доступные команды:\n\n"
        "/sex - случайная пара 'выебал'\n"
        "/video - случайное фото из сохраненных\n"
        "/stats - статистика группы\n"
        "/help - это сообщение\n\n"
        "📸 Как работают фото:\n"
        "1. Бот автоматически запоминает ВСЕ новые фото в группе\n"
        "2. По команде /video показывает случайное из сохраненных\n\n"
        "⚠️ Важно: бот должен быть администратором группы!"
    )

def main():
    app = Application.builder().token(BOT_TOKEN).build()

    app.add_handler(CommandHandler("sex", sex_command))
    app.add_handler(CommandHandler("video", video_command))
    app.add_handler(CommandHandler("stats", stats_command))
    app.add_handler(CommandHandler("help", help_command))
    app.add_handler(CommandHandler("start", help_command))
    app.add_handler(MessageHandler(filters.PHOTO, handle_new_photo))

    port = int(os.environ.get("PORT", 8080))
    
    print("🤖 Бот запущен на Render...")
    print("Доступные команды: /sex, /video, /stats, /help")
    
    # Для Render нужно использовать webhook или polling с портом
    app.run_webhook(
        listen="0.0.0.0",
        port=port,
        webhook_url=f"https://{os.environ.get('RENDER_EXTERNAL_HOSTNAME', 'localhost')}/webhook"
    )

if __name__ == "__main__":
    main()
