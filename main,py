# --- ГЛАВНАЯ ФУНКЦИЯ ЗАПУСКА ---
def main():
    app = Application.builder().token(BOT_TOKEN).build()

    # Добавляем обработчики команд
    app.add_handler(CommandHandler("sex", sex_command))
    app.add_handler(CommandHandler("video", video_command))
    app.add_handler(CommandHandler("stats", stats_command))
    app.add_handler(CommandHandler("help", help_command))

    # Добавляем обработчик для автоматического сохранения новых фото
    app.add_handler(CommandHandler("start", help_command))  # /start тоже показывает помощь
    # Этот обработчик будет ловить все сообщения с фото
    # ВАЖНО: Он должен быть последним, чтобы не конфликтовать с командами
    from telegram.ext import MessageHandler, filters
    app.add_handler(MessageHandler(filters.PHOTO, handle_new_photo))

    print("🤖 Бот запущен...")
    print("Доступные команды: /sex, /video, /stats, /help")
    print("\n📸 Как это работает:")
    print("1. Бот автоматически запоминает ВСЕ фото в группе")
    print("2. По команде /video показывает случайное сохраненное фото")
    print("3. Для /sex бот должен быть администратором")
    print("\n⚠️ Убедитесь, что бот является администратором группы!")

    app.run_polling()


if __name__ == "__main__":
    main()
